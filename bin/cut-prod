#!/usr/bin/env bash
# Promote the current rc/<x.y.z> branch to prod/<x.y.z>.
# Strips the rc qualifier from pyproject.toml, commits, and pushes —
# triggering publish.yml.
set -euo pipefail

BRANCH=$(git branch --show-current)
if [[ ! "$BRANCH" =~ ^rc/ ]]; then
    echo "error: cut-prod must be run on an rc/* branch (current: ${BRANCH:-detached HEAD})" >&2
    exit 1
fi

git fetch origin "$BRANCH"
AHEAD=$(git rev-list "origin/${BRANCH}..HEAD" --count)
if [[ "$AHEAD" -gt 0 ]]; then
    echo "error: local ${BRANCH} is $AHEAD commit(s) ahead of origin — push first" >&2
    exit 1
fi

eval "$(python - <<'PY'
import re, sys, tomllib

with open("pyproject.toml", "rb") as f:
    current = tomllib.load(f)["project"]["version"]

m = re.fullmatch(r"(\d+)\.(\d+)\.(\d+)-rc\.(\d+)", current)
if not m:
    sys.exit(f"expected X.Y.Z-rc.N in pyproject.toml, got: {current!r}")

new = f"{m.group(1)}.{m.group(2)}.{m.group(3)}"

with open("pyproject.toml") as f:
    text = f.read()
updated = re.sub(r'^(version\s*=\s*")[^"]*(")', rf'\g<1>{new}\2', text, flags=re.MULTILINE)
assert updated != text, "version= line not found in pyproject.toml"
with open("pyproject.toml", "w") as f:
    f.write(updated)

print(f"version: {current} → {new}", file=sys.stderr)
print(f"PROD_VERSION={new}")
print(f"PROD_BRANCH=prod/{new}")
PY
)"

git checkout -B "$PROD_BRANCH"
git add pyproject.toml
git commit -m "chore: release $PROD_VERSION"
git push origin "$PROD_BRANCH"
