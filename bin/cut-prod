#!/usr/bin/env bash
set -euo pipefail

BRANCH=$(git branch --show-current)
if [[ ! "$BRANCH" =~ ^rc/ ]]; then
    echo "error: must be run on an rc/* branch (current: ${BRANCH:-detached HEAD})" >&2
    exit 1
fi

git fetch origin "$BRANCH"
AHEAD=$(git rev-list "origin/${BRANCH}..HEAD" --count 2>/dev/null || echo 0)
if [[ "$AHEAD" -gt 0 ]]; then
    echo "error: local ${BRANCH} is $AHEAD commit(s) ahead of origin — push first" >&2
    exit 1
fi

gh workflow run release.yml --ref "$BRANCH" -f action=cut-prod -f bump_type=dev
gh run watch
