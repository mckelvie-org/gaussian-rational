#!/usr/bin/env bash
# Promote the current rc/<x.y.z> branch to prod/<x.y.z>.
# Strips the rc qualifier from pyproject.toml, commits, and pushes —
# triggering publish.yml.
# Uses a git worktree so the dev's working directory is never modified.
set -euo pipefail

BRANCH=$(git branch --show-current)
if [[ ! "$BRANCH" =~ ^rc/ ]]; then
    echo "error: cut-prod must be run on an rc/* branch (current: ${BRANCH:-detached HEAD})" >&2
    exit 1
fi

git fetch origin "$BRANCH"
AHEAD=$(git rev-list "origin/${BRANCH}..HEAD" --count)
if [[ "$AHEAD" -gt 0 ]]; then
    echo "error: local ${BRANCH} is $AHEAD commit(s) ahead of origin — push first" >&2
    exit 1
fi

eval "$(python - <<'PY'
import re, sys

with open("pyproject.toml") as f:
    text = f.read()
vm = re.search(r'^version\s*=\s*"([^"]*)"', text, re.MULTILINE)
if not vm:
    sys.exit("version= line not found in pyproject.toml")
current = vm.group(1)

m = re.fullmatch(r"(\d+)\.(\d+)\.(\d+)-rc\.(\d+)", current)
if not m:
    sys.exit(f"expected X.Y.Z-rc.N in pyproject.toml, got: {current!r}")

new = f"{m.group(1)}.{m.group(2)}.{m.group(3)}"

print(f"version: {current} → {new}", file=sys.stderr)
print(f"PROD_VERSION={new}")
print(f"PROD_BRANCH=prod/{new}")
PY
)"

TMP=$(mktemp -d)
trap 'git worktree remove --force "$TMP" 2>/dev/null; rm -rf "$TMP"' EXIT

git worktree add --detach "$TMP" HEAD

python - "$PROD_VERSION" "$TMP/pyproject.toml" <<'PY'
import re, sys
new, path = sys.argv[1], sys.argv[2]
with open(path) as f:
    text = f.read()
updated = re.sub(r'^(version\s*=\s*")[^"]*(")', rf'\g<1>{new}\2', text, flags=re.MULTILINE)
assert updated != text, "version= line not found in pyproject.toml"
with open(path, "w") as f:
    f.write(updated)
PY

git -C "$TMP" checkout -b "$PROD_BRANCH"
git -C "$TMP" add pyproject.toml
git -C "$TMP" commit -m "chore: release $PROD_VERSION"
git -C "$TMP" push origin "$PROD_BRANCH"
